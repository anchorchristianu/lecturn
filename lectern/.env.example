# Required: your Anthropic API key (server-side only — never exposed to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Required for accounts: a long random string used to sign session cookies.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Optional: require this code to create an account (keeps signup invite-only).
# Leave blank to allow open registration.
SIGNUP_CODE=

# Optional model overrides (sensible defaults are baked in)
MODEL_MAIN=claude-sonnet-4-6
MODEL_SORT=claude-haiku-4-5
